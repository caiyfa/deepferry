# deepferry — Docker Compose 环境变量
# 复制此文件为 .env 并填入实际值

# ── deepferry 服务 ───────────────────────────────────────────────────────
# 可选：SQLite 数据库路径（容器内路径，通常无需修改）
# DEEPFERRY_DB_PATH=/home/deepferry/data/deepferry.db

# ── MySQL ────────────────────────────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=testpass
MYSQL_DATABASE=deepferry

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=testpass
POSTGRES_DATABASE=deepferry
